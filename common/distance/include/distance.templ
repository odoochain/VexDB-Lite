#define METRIC_ENUM_SEQ (Metric::SPHERICAL)(Metric::L2_SQRT)(Metric::L2_NORM)
#define REMAINDER_SITUATION_ENUM_SEQ (RemainderSituation::Unknown)
#define ALIGNED_SEQ (false)
#define PRODUCT_SETS \
    (METRIC_ENUM_SEQ) \
    (DIST_PRECISION_TYPE_ENUM_SEQ) \
    (REMAINDER_SITUATION_ENUM_SEQ) \
    (ALIGNED_SEQ)

#undef DECLARE_IMPL2
#undef RENDER_PRODUCTS
#define DECLARE_IMPL2(r, product) \
    void DISTANCER_TEMPLATE(r, product)::get_distance_batch2( \
        const void *x, void *const *y, uint16 dim, uint16 y_size, float *out) const \
    { Assert(false); }
#define RENDER_PRODUCTS(r, product) \
    DECLARE_DISTANCER(r, product) \
    DECLARE_IMPL1(r, product) \
    DECLARE_IMPL2(r, product) \
