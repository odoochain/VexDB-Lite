# Delete 40% of high-dim data
statement ok
DELETE FROM vectors_hd WHERE id % 5 IN (0, 1);

query I
SELECT count(*) FROM vectors_hd;
----
180

# Search after large delete on high-dim index
query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 2)) LIMIT 10);
----
10

statement ok
CHECKPOINT;

# Search after checkpoint
query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 3)) LIMIT 10);
----
10

# ============================================================
# Phase 12: Drop and recreate index on existing data
# ============================================================
statement ok
DROP INDEX idx_hd;

statement ok
CREATE INDEX idx_hd2 ON vectors_hd USING GRAPH_INDEX (vec);

# Search on recreated index
query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 4)) LIMIT 10);
----
10

# ============================================================
# Phase 13: Varied LIMIT sizes
# ============================================================
query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 7)) LIMIT 1);
----
1

query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 7)) LIMIT 50);
----
50

query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 7)) LIMIT 100);
----
100

# LIMIT larger than table size — should return all rows
query I
SELECT count(*) FROM (SELECT id FROM vectors_hd ORDER BY l2_distance(vec, (SELECT vec FROM vectors_hd WHERE id = 7)) LIMIT 500);
----
180

