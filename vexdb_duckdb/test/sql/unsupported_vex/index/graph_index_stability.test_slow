# ============================================================
# Phase 11: High-dimension stress (recreate with 128-dim)
# ============================================================
statement ok
DROP INDEX idx_stable;

statement ok
DROP TABLE vectors;

statement ok
CREATE TABLE vectors_hd (id INTEGER PRIMARY KEY, vec FLOAT[128]);

statement ok
CREATE INDEX idx_hd ON vectors_hd USING GRAPH_INDEX (vec);

# Insert 300 rows of 128-dim vectors
statement ok
INSERT INTO vectors_hd
SELECT i,
    list_value(
        sin(i*0.01)::FLOAT, cos(i*0.02)::FLOAT, sin(i*0.03)::FLOAT, cos(i*0.04)::FLOAT,
        sin(i*0.05)::FLOAT, cos(i*0.06)::FLOAT, sin(i*0.07)::FLOAT, cos(i*0.08)::FLOAT,
