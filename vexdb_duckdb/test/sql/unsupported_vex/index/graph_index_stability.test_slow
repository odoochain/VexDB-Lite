        sin(i*0.41)::FLOAT, cos(i*0.42)::FLOAT, sin(i*0.43)::FLOAT, cos(i*0.44)::FLOAT,
        sin(i*0.45)::FLOAT, cos(i*0.46)::FLOAT, sin(i*0.47)::FLOAT, cos(i*0.48)::FLOAT,
        sin(i*0.49)::FLOAT, cos(i*0.50)::FLOAT, sin(i*0.51)::FLOAT, cos(i*0.52)::FLOAT,
        sin(i*0.53)::FLOAT, cos(i*0.54)::FLOAT, sin(i*0.55)::FLOAT, cos(i*0.56)::FLOAT,
        sin(i*0.57)::FLOAT, cos(i*0.58)::FLOAT, sin(i*0.59)::FLOAT, cos(i*0.60)::FLOAT,
        sin(i*0.61)::FLOAT, cos(i*0.62)::FLOAT, sin(i*0.63)::FLOAT, cos(i*0.64)::FLOAT,
