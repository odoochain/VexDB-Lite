    sin(i)::FLOAT, cos(i)::FLOAT, sin(i*2)::FLOAT, cos(i*2)::FLOAT,
    sin(i*3)::FLOAT, cos(i*3)::FLOAT, sin(i*4)::FLOAT, cos(i*4)::FLOAT
)::FLOAT[8] FROM range(901, 951) t(i);

