----
0

# Rebuild index from empty
statement ok
INSERT INTO vectors SELECT i, list_value(
    sin(i * 0.1)::FLOAT, cos(i * 0.2)::FLOAT, sin(i * 0.3)::FLOAT, cos(i * 0.4)::FLOAT,
